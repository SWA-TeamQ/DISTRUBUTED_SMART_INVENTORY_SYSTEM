{
    "files.associations": {
        "*.css": "css"
    },
    "css.lint.vendorPrefix": "ignore",
    "css.lint.fontFaceProperties": "ignore",
    "[css]": {
        "editor.quickSuggestions": {
            "comments": "on",
            "strings": "on",
            "other": "on"
        }
    },
    "chat.tools.terminal.autoApprove": {
        "mvn compile": true,
        "mvn exec:java": true,
        "mvn clean": true
    }
}
