<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import java.net.URL?>

<BorderPane xmlns="http://javafx.com/javafx/17"
    xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controllers.GalleryController" styleClass="page-shell">
    <stylesheets>
        <URL value="@../css/style.css" />
    </stylesheets>
    
    <top>
        <HBox spacing="16" alignment="CENTER_LEFT" styleClass="page-header">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Gallery" styleClass="page-title"/>
                <Label text="Browse active auctions in a modern structured list." styleClass="page-subtitle" wrapText="true"/>
            </VBox>
            <Button text="Back to Dashboard" onAction="#handleBackToDashboard" styleClass="secondary-button"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="16" styleClass="main-stack">
            <VBox spacing="10" styleClass="panel-card">
                <Label text="Filters" styleClass="section-title"/>
                <HBox spacing="10">
                    <TextField promptText="Search auctions" styleClass="search-field" HBox.hgrow="ALWAYS"/>
                    <Button text="Search" styleClass="primary-button"/>
                </HBox>
            </VBox>

            <VBox spacing="10" styleClass="panel-card" VBox.vgrow="ALWAYS">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label text="Active Auctions" styleClass="section-title"/>
                        <Label text="Double click an item to see details and bid." styleClass="section-copy" wrapText="true"/>
                    </VBox>
                    <Label fx:id="statusLabel" text="Loading..." styleClass="status-chip status-chip-accent"/>
                </HBox>

                <ListView fx:id="auctionListView" VBox.vgrow="ALWAYS" onMouseClicked="#handleDoubleClick" styleClass="auction-table"/>
                
                <HBox spacing="10">
                    <Button text="Open Selected Auction" onAction="#openSelectedAuction" styleClass="primary-button"/>
                </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>
