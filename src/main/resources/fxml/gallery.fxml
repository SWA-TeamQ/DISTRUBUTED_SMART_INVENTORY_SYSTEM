<?xml version="1.0" encoding="UTF-8"?>
<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
    xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controllers.GalleryController" styleClass="page-shell">
    <stylesheets>
        <URL value="@../css/style.css" />
    </stylesheets>

    <top>
        <VBox spacing="14" styleClass="page-header">
            <BorderPane>
                <left>
                    <VBox spacing="4">
                        <Label text="Gallery" styleClass="page-title" />
                        <Label text="A card-based view over the exact same shared auction list used by the dashboard table." styleClass="page-subtitle" wrapText="true" />
                    </VBox>
                </left>
                <right>
                    <Button fx:id="backButton" text="Back to Dashboard" onAction="#handleBackToDashboard" styleClass="secondary-button" />
                </right>
            </BorderPane>
            <VBox spacing="10" styleClass="panel-card">
                <Label text="Filters" styleClass="section-title" />
                <TextField fx:id="searchField" promptText="Search auctions" styleClass="search-field" onAction="#handleSearch" />
            </VBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="12" styleClass="main-stack">
            <BorderPane styleClass="panel-card">
                <left>
                    <VBox spacing="4">
                        <Label text="Auction Grid" styleClass="section-title" />
                        <Label text="Cards update when the shared ObservableList changes, so the table and gallery never drift." styleClass="section-copy" wrapText="true" />
                    </VBox>
                </left>
                <right>
                    <Label fx:id="auctionCountLabel" text="0 auction(s)" styleClass="status-chip status-chip-accent" />
                </right>
            </BorderPane>

            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="content-scroll" VBox.vgrow="ALWAYS">
                <content>
                    <TilePane fx:id="auctionGrid" hgap="16" vgap="16" prefColumns="4" styleClass="main-stack" />
                </content>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
