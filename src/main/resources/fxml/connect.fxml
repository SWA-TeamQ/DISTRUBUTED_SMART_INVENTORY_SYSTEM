<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controllers.ConnectController" spacing="15" alignment="CENTER">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Connect to Server" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>

    <Label text="Discovered Servers (UDP):"/>
    <ListView fx:id="serverListView" prefHeight="200" prefWidth="400"/>

    <HBox spacing="10" alignment="CENTER">
        <Label text="Manual IP:"/>
        <TextField fx:id="ipField" promptText="localhost"/>
        <Label text="Port:"/>
        <TextField fx:id="portField" promptText="1099" prefWidth="80"/>
    </HBox>

    <Button text="Connect" onAction="#handleConnect" defaultButton="true" prefWidth="200" styleClass="accent"/>
    
    <Label fx:id="statusLabel" textFill="red"/>
</VBox>
