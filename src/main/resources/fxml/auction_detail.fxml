<?xml version="1.0" encoding="UTF-8"?>
<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
    xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controllers.AuctionDetailController" styleClass="page-shell">
    <stylesheets>
        <URL value="@../css/style.css" />
    </stylesheets>

    <top>
        <HBox spacing="16" alignment="CENTER_LEFT" styleClass="page-header">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label fx:id="titleLabel" text="Auction Detail" styleClass="page-title" />
                <Label fx:id="subtitleLabel" text="Auction details, thumbnails, and live bidding live here." styleClass="page-subtitle" wrapText="true" />
            </VBox>
            <Button fx:id="backButton" text="Back" onAction="#handleBackToPreviousView" styleClass="secondary-button" />
        </HBox>
    </top>

    <center>
        <VBox spacing="16" styleClass="main-stack">
            <HBox spacing="16" VBox.vgrow="ALWAYS">
                <VBox spacing="12" styleClass="panel-card" HBox.hgrow="ALWAYS">
                    <Label text="Media" styleClass="section-title" />
                    <VBox styleClass="hero-card" prefHeight="360" VBox.vgrow="ALWAYS">
                        <ImageView fx:id="heroImageView" fitWidth="720" fitHeight="360" preserveRatio="true" pickOnBounds="true" />
                    </VBox>
                    <Label text="Thumbnails" styleClass="section-copy" />
                    <ListView fx:id="thumbnailListView" prefHeight="120" />
                </VBox>

                <VBox spacing="12" styleClass="panel-card" prefWidth="420" maxWidth="420">
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label fx:id="statusLabel" text="ACTIVE" styleClass="status-chip status-chip-success" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="timeLeftLabel" text="--:--" styleClass="status-chip status-chip-accent" />
                    </HBox>

                    <Label fx:id="sellerLabel" text="Seller: -" styleClass="section-copy" />
                    <Label fx:id="highestBidderLabel" text="Highest bidder: -" styleClass="section-copy" />

                    <VBox spacing="8" styleClass="hero-card">
                        <Label text="Current Highest Bid" styleClass="section-title" />
                        <Label fx:id="currentHighestBidLabel" text="ETB 0.00" styleClass="metric-value" />
                        <Label fx:id="minimumBidLabel" text="Minimum next bid: ETB 0.00" styleClass="section-copy" wrapText="true" />
                    </VBox>

                    <VBox spacing="8" styleClass="hero-card">
                        <Label text="Place Bid" styleClass="section-title" />
                        <TextField fx:id="bidAmountField" promptText="Enter amount" styleClass="compact-field" />
                        <Button fx:id="placeBidButton" text="Place Bid" onAction="#handlePlaceBid" styleClass="primary-button" maxWidth="Infinity" />
                        <Label fx:id="bidStatusLabel" text="" styleClass="section-copy" wrapText="true" />
                    </VBox>

                    <VBox spacing="8" styleClass="hero-card">
                        <Label text="Description" styleClass="section-title" />
                        <Label fx:id="descriptionLabel" text="-" wrapText="true" styleClass="section-copy" />
                    </VBox>
                </VBox>
            </HBox>
        </VBox>
    </center>
</BorderPane>
