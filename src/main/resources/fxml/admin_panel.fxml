<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns="http://javafx.com/javafx/17"
    xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controllers.AdminPanelController" styleClass="admin-shell">
    <top>
        <HBox styleClass="page-header" spacing="16" alignment="CENTER_LEFT" BorderPane.alignment="CENTER">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Admin Console" styleClass="page-title"/>
                <Label text="Manage users, auctions and system audits." styleClass="page-subtitle" wrapText="true"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <HBox spacing="8" alignment="CENTER_RIGHT">
                <Button onAction="#handleRefresh" styleClass="secondary-button">Refresh</Button>
                <Button onAction="#handleLogout" styleClass="button-danger">Logout</Button>
            </HBox>
        </HBox>
    </top>
    <left>
        <VBox styleClass="sidebar-nav" prefWidth="200" spacing="12" padding="16">
            <Label text="Admin Console" styleClass="sidebar-header"/>
            <Button onAction="#showUsers" styleClass="nav-button" maxWidth="Infinity">
                <graphic>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <FontIcon iconLiteral="fas-users" iconSize="14"/>
                        <Label text="Users"/>
                    </HBox>
                </graphic>
            </Button>
            <Button onAction="#showAuctions" styleClass="nav-button" maxWidth="Infinity">
                <graphic>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <FontIcon iconLiteral="fas-gavel" iconSize="14"/>
                        <Label text="Auctions"/>
                    </HBox>
                </graphic>
            </Button>
            <Button onAction="#showLogs" styleClass="nav-button" maxWidth="Infinity">
                <graphic>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <FontIcon iconLiteral="fas-list" iconSize="14"/>
                        <Label text="Audit Logs"/>
                    </HBox>
                </graphic>
            </Button>
            <Region VBox.vgrow="ALWAYS" />
            <VBox spacing="8">
                <Separator styleClass="sidebar-separator"/>
                <Button onAction="#handleRefreshDashboard" styleClass="secondary-button" maxWidth="Infinity">
                    <graphic>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <FontIcon iconLiteral="fas-sync" iconSize="14"/>
                            <Label text="Refresh All"/>
                        </HBox>
                    </graphic>
                </Button>
                <Button onAction="#handleLogout" styleClass="button-danger" maxWidth="Infinity">
                    <graphic>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <FontIcon iconLiteral="fas-sign-out-alt" iconSize="14"/>
                            <Label text="Logout"/>
                        </HBox>
                    </graphic>
                </Button>
            </VBox>
        </VBox>
    </left>
    <center>
        <VBox fx:id="contentArea" styleClass="admin-content" spacing="20" style="-fx-padding: 25;">
            <!-- Placeholder for dynamic content -->
        </VBox>
    </center>
</BorderPane>
