<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
    xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controllers.AdminPanelController" styleClass="page-shell admin-shell">

    <top>
        <HBox spacing="16" alignment="CENTER_LEFT" styleClass="admin-header">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Admin Panel" styleClass="page-title"/>
                <Label text="Manage users, auctions, and audit activity from one control surface." styleClass="page-subtitle" wrapText="true"/>
            </VBox>

            <VBox spacing="4" alignment="CENTER_RIGHT">
                <Label fx:id="lastUpdatedLabel" text="Updated just now" styleClass="status-chip status-chip-accent"/>
                <Label text="Session active" styleClass="status-chip status-chip-success"/>
            </VBox>

            <Button text="Refresh" onAction="#handleRefreshDashboard" styleClass="secondary-button"/>
            <Button text="Logout" onAction="#handleLogout" styleClass="secondary-button"/>
        </HBox>
    </top>

    <left>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="panel-scroll admin-sidebar-scroll">
            <content>
                <VBox spacing="16" styleClass="sidebar-stack admin-sidebar">
                    <VBox spacing="10" styleClass="panel-card">
                        <Label text="Navigation" styleClass="panel-title"/>
                        <Label text="Switch between users, auctions, and logs." styleClass="panel-copy" wrapText="true"/>
                        <Button text="Users" onAction="#showUsers" maxWidth="Infinity" styleClass="nav-button"/>
                        <Button text="Auctions" onAction="#showAuctions" maxWidth="Infinity" styleClass="nav-button"/>
                        <Button text="Audit Logs" onAction="#showLogs" maxWidth="Infinity" styleClass="nav-button"/>
                    </VBox>

                    <VBox spacing="10" styleClass="panel-card">
                        <Label text="System Tools" styleClass="panel-title"/>
                        <Label text="Maintenance actions that affect the whole system." styleClass="panel-copy" wrapText="true"/>
                        <Button text="Backup Database" onAction="#handleBackup" maxWidth="Infinity" styleClass="secondary-button"/>
                        <Label fx:id="statusLabel" wrapText="true" styleClass="status-line"/>
                    </VBox>
                </VBox>
            </content>
        </ScrollPane>
    </left>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="panel-scroll">
            <content>
                <VBox fx:id="contentArea" spacing="18" styleClass="main-stack admin-content"/>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
